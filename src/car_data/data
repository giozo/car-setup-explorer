// ============================================================
// SetupLab — Car Profiles
// Source of truth for every car's available setup parameters.
// Generated from AC min/max calibration setups.
//
// To add a new car:
//   1. In AC, save a setup with EVERYTHING at minimum → setuplab_min
//   2. Save a setup with EVERYTHING at maximum  → setuplab_max
//   3. Run build_profile.py against those two files
//   4. Paste the output as a new entry in CAR_PROFILES below
// ============================================================

export type Game = "ac" | "acc" | "lmu" | "raceroom" | "iracing";
export type Drive = "RWD" | "FWD" | "AWD";
export type EngineLayout = "front" | "mid" | "rear";
export type Tab =
  | "AERO"
  | "TYRES"
  | "SUSPENSIONS"
  | "ALIGNMENT"
  | "DAMPERS"
  | "DRIVETRAIN"
  | "ELECTRONICS"
  | "GEARS"
  | "GENERIC";

export interface ParameterDef {
  key: string;
  label: string;
  unit: string;
  tab: Tab;
  min: number;
  max: number;
  clicks: number;
}

export interface CarProfile {
  id: string;
  name: string;
  game: Game;
  class: string;
  engineLayout: EngineLayout;
  drive: Drive;
  parameters: ParameterDef[];
}

// ── Helper ────────────────────────────────────────────────────
/** Returns only the parameters for a given tab */
export function getParametersByTab(
  car: CarProfile,
  tab: Tab
): ParameterDef[] {
  return car.parameters.filter((p) => p.tab === tab);
}

/** Returns all tabs that this car actually has parameters for */
export function getAvailableTabs(car: CarProfile): Tab[] {
  const tabs = new Set(car.parameters.map((p) => p.tab));
  // Return in a logical display order
  const ORDER: Tab[] = [
    "AERO",
    "TYRES",
    "SUSPENSIONS",
    "ALIGNMENT",
    "DAMPERS",
    "DRIVETRAIN",
    "ELECTRONICS",
    "GEARS",
    "GENERIC",
  ];
  return ORDER.filter((t) => tabs.has(t));
}

/** Normalize a raw value to 0–1 within this parameter's range */
export function normalize(param: ParameterDef, value: number): number {
  if (param.max === param.min) return 0;
  return Math.max(0, Math.min(1, (value - param.min) / (param.max - param.min)));
}

