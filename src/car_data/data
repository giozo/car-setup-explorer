// ── Lookup helpers ────────────────────────────────────────────
export function getCarById(id: string): CarProfile | undefined {
  return CAR_PROFILES.find((c) => c.id === id);
}

export function getCarsByGame(game: Game): CarProfile[] {
  return CAR_PROFILES.filter((c) => c.game === game);
}

export function getCarsByClass(cls: string): CarProfile[] {
  return CAR_PROFILES.filter((c) => c.class === cls);
}
